+pub fn remap_evdev_for_app(code: u16) -> u16 {
+    match code {
+        1 => 190,  // KEY_ESC -> KEY_F20 (Wispr PTT)
+        58 => 1,   // KEY_CAPSLOCK -> KEY_ESC
+        other => other,
+    }
+}
